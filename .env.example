DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
# Optional fallback channel for legacy watches. New watches alert in the channel
# where an authorized manager added them.
DISCORD_CHANNEL_ID=
# Required for watch commands in DMs; always permitted for watch management.
DISCORD_OWNER_ID=
# Optional Discord role allowed to manage watches in addition to Manage Server.
WATCH_MANAGER_ROLE_ID=

# Required for Discord download links. Use a public or LAN URL that users can open.
PUBLIC_BASE_URL=https://example.com
HTTP_PORT=8080

POLL_INTERVAL_SECONDS=60
PROFILE_SCAN_LIMIT=5
PROFILE_BURST_SCAN_LIMIT=20
MONITOR_CONCURRENCY=2
DISCORD_UPLOAD_LIMIT_MB=10
DOWNLOAD_LINK_TTL_MINUTES=30
# Retains inactive job/history metadata for this many days. File expiry is
# controlled by active links and is cleaned as soon as no active link remains.
RETENTION_DAYS=30
MAX_CONCURRENT_DOWNLOADS=1
MAX_DOWNLOAD_QUEUE_SIZE=50
MAX_QUEUED_DOWNLOADS_PER_USER=3
MAX_QUEUED_DOWNLOADS_PER_GUILD=12
# Creator imports default to videos up to two minutes. The dashboard can
# override this per import (1-3600 seconds).
IMPORT_MAX_DURATION_SECONDS=120
IMPORT_CONCURRENCY=1
IMPORT_PROFILE_TIMEOUT_SECONDS=600
# Optional bearer token for non-loopback import API callers. The local SSH
# bridge invokes the API from inside the app container and does not require it.
IMPORT_API_TOKEN=
CLEANUP_BATCH_SIZE=100
DELETION_CHECK_CONCURRENCY=2
DELETION_CHECK_BATCH_SIZE=25

# Bounds for direct HTTP media fallbacks and slideshow ZIP creation.
FETCH_TIMEOUT_SECONDS=30
MAX_SLIDESHOW_IMAGES=35
MAX_SLIDESHOW_ITEM_MB=20
MAX_SLIDESHOW_TOTAL_MB=250
MAX_MEDIA_DOWNLOAD_MB=2048

# none, here, everyone, or role
PING_MODE=none
PING_ROLE_ID=

DATA_DIR=./data
STATE_DB=./data/state.db
DOWNLOAD_DIR=./data/downloads
YTDLP_PATH=yt-dlp
# YTDLP_COOKIES_FILE=./cookies/tiktok.txt
YTDLP_RETRIES=3
YTDLP_TIMEOUT_SECONDS=60

# true registers slash commands at startup. You can also run npm run register:commands.
REGISTER_COMMANDS_ON_START=false

# Optional: enable the cloudflared Compose profile after creating a Cloudflare
# Tunnel for example.com -> http://tiktok-discord-downloader:8080.
CLOUDFLARE_TUNNEL_TOKEN=
